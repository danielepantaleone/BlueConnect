{"abstract":[{"type":"text","text":"Waits asynchronously until the central manager is in the "},{"type":"codeVoice","code":".poweredOn"},{"text":" state, or throws an error if the state is unauthorized or unsupported.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"extendedModule":"BlueConnect","externalID":"s:11BlueConnect22BleCentralManagerProxyC14waitUntilReady7timeouty8Dispatch0K12TimeIntervalO_tYaKF","symbolKind":"method","title":"waitUntilReady(timeout:)","roleHeading":"Instance Method","role":"symbol","modules":[{"name":"BlueConnect"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"waitUntilReady","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"timeout"},{"kind":"text","text":": "},{"preciseIdentifier":"s:8Dispatch0A12TimeIntervalO","kind":"typeIdentifier","text":"DispatchTimeInterval"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"text":" ","kind":"text"},{"kind":"keyword","text":"throws"}]},"variants":[{"paths":["\/documentation\/blueconnect\/blecentralmanagerproxy\/waituntilready(timeout:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/BlueConnect\/documentation\/BlueConnect","doc:\/\/BlueConnect\/documentation\/BlueConnect\/BleCentralManagerProxy"]]},"identifier":{"url":"doc:\/\/BlueConnect\/documentation\/BlueConnect\/BleCentralManagerProxy\/waitUntilReady(timeout:)","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"waitUntilReady","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"timeout"},{"text":": ","kind":"text"},{"text":"DispatchTimeInterval","preciseIdentifier":"s:8Dispatch0A12TimeIntervalO","kind":"typeIdentifier"},{"text":" = .never) ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"timeout","content":[{"inlineContent":[{"text":"The maximum duration to wait for the central manager to be ready. The default value is ","type":"text"},{"code":".never","type":"codeVoice"},{"text":", indicating no timeout.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"This method uses an async\/await pattern to wait for the central manager to become ready. It checks the central manager’s state and resumes"},{"type":"text","text":" "},{"type":"text","text":"with success if it is already "},{"type":"codeVoice","code":".poweredOn"},{"type":"text","text":". Otherwise, it waits until the state changes to "},{"code":".poweredOn","type":"codeVoice"},{"type":"text","text":" within the specified timeout."},{"text":" ","type":"text"},{"type":"text","text":"If the state is unauthorized or unsupported, it throws an error."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Example usage:"}],"type":"paragraph"},{"type":"codeListing","code":["do {","    try await centralManagerProxy.waitUntilReady(timeout: .seconds(5))","    \/\/ Central manager is ready","} catch {","    \/\/ Handle error (e.g., unsupported or unauthorized state)","}"],"syntax":"swift"},{"content":[{"inlineContent":[{"text":"An error if the it’s not possible to wait for the central manager to be ready within the provided timeout.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Throws"}],"kind":"content"}],"references":{"doc://BlueConnect/documentation/BlueConnect":{"title":"BlueConnect","kind":"symbol","abstract":[],"role":"collection","identifier":"doc:\/\/BlueConnect\/documentation\/BlueConnect","type":"topic","url":"\/documentation\/blueconnect"},"doc://BlueConnect/documentation/BlueConnect/BleCentralManagerProxy/waitUntilReady(timeout:)":{"